# Backend Environment Variables - Blood Connect Pro

# ============ DATABASE ============
MONGO_URI=mongodb://your_mongo_connection_string_here

# ============ SERVER ============
PORT=5000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_key_here_min_32_characters

# ============ EMAIL SERVICE (MAILTRAP) ============
# Get your Mailtrap credentials from: https://mailtrap.io/
MAILTRAP_HOST=smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=your_mailtrap_username_here
MAILTRAP_PASS=your_mailtrap_password_here

# ============ EMAIL CONFIGURATION ============
FROM_EMAIL=noreply@bloodconnectpro.com
FROM_NAME=Blood Connect Pro

# ============ URLS ============
# Backend URL for generating verification links
BACKEND_URL=http://localhost:5000

# Frontend URL for password reset links
FRONTEND_URL=http://localhost:5173

# ============ SMTP (Alternative to Mailtrap) ============
# If you want to use a different SMTP provider (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_specific_password

# ============ CORS ============
CORS_ORIGIN=http://localhost:5173

# ============ OPTIONAL SERVICES ============
# For SMS verification (future implementation)
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+1234567890
