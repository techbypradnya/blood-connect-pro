{
  "info": {
    "name": "Blood Connect Pro API",
    "_postman_id": "blood-connect-pro",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Aarav Sharma\",\n  \"email\": \"aarav@example.com\",\n  \"phone\": \"+91 98765 43210\",\n  \"password\": \"password123\",\n  \"role\": \"donor\",\n  \"bloodGroup\": \"O+\",\n  \"city\": \"Mumbai\",\n  \"state\": \"Maharashtra\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"aarav@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/verify-email",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"PASTE_TOKEN_FROM_EMAIL_LINK_HERE\"\n}"
            },
            "description": "Send the verification token from the email link query parameter (?token=...) in the request body."
          }
        },
        {
          "name": "Resend Verification Email",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/resend-verification",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"aarav@example.com\"\n}"
            },
            "description": "Resend the verification email for an unverified user."
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/forgot-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"aarav@example.com\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/auth/reset-password/:token",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"newpassword123\"\n}"
            },
            "description": "Replace :token with the reset token received in the password reset email."
          }
        },
        {
          "name": "Send Phone OTP",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/send-otp",
            "description": "Requires Bearer token. Sends a 6-digit OTP to the logged-in user's phone (logged to console in dev)."
          }
        },
        {
          "name": "Verify Phone OTP",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/verify-otp",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"otp\": \"123456\"\n}"
            },
            "description": "Requires Bearer token. Submit the 6-digit OTP to verify the phone number."
          }
        }
      ]
    },
    {
      "name": "Donors",
      "item": [
        {
          "name": "Get All Donors",
          "request": { "method": "GET", "url": "{{baseUrl}}/donors" }
        },
        {
          "name": "Search Donors",
          "request": { "method": "GET", "url": "{{baseUrl}}/donors/search?bloodGroup=O+&city=Mumbai" }
        },
        {
          "name": "Toggle Availability",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/donors/availability",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"available\": false }" }
          }
        }
      ]
    },
    {
      "name": "Blood Requests",
      "item": [
        {
          "name": "Create Request",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/requests",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bloodGroup\": \"O+\",\n  \"unitsRequired\": 2,\n  \"hospitalName\": \"City Hospital\",\n  \"city\": \"Mumbai\",\n  \"contactNumber\": \"+91 98765 43210\"\n}"
            }
          }
        },
        {
          "name": "Get All Requests",
          "request": { "method": "GET", "url": "{{baseUrl}}/requests" }
        },
        {
          "name": "Update Request",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/requests/:id",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"status\": \"accepted\" }" }
          }
        },
        {
          "name": "Delete Request",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/requests/:id" }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get All Users (Admin)",
          "request": { "method": "GET", "url": "{{baseUrl}}/users" }
        },
        {
          "name": "Get User by ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/users/:id" }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/users/:id",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"city\": \"Delhi\" }" }
          }
        },
        {
          "name": "Delete User",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/users/:id" }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/dashboard" }
        }
      ]
    }
  ]
}
